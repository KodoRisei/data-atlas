# ── Catalog database (DataAtlas metadata store) ─────────────────────────────
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/data_atlas

# ── AI provider ──────────────────────────────────────────────────────────────
# One of: openai | anthropic | ollama
AI_PROVIDER=openai

OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Ingestion defaults ───────────────────────────────────────────────────────
# Default target database to scan (can be overridden per request)
TARGET_DB_URL=postgresql://user:password@localhost:5432/your_database
